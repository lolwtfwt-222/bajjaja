{
  "exclude": ["node_modules"],
  "include": ["./Source"],
  "compilerOptions": {
    "incremental": true,
    "target": "ESNext",
    "lib": ["ESNext"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "module": "Node16",
    "moduleResolution": "Node16",
    "types": ["node"],
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "outDir": "./bin/",
    "rootDir": "./Source", 
    "importHelpers": true,
    "noEmitHelpers": true,
    "esModuleInterop": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": false,
    "alwaysStrict": true,
    "skipLibCheck": true,
    "noErrorTruncation": true,
    "forceConsistentCasingInFileNames": true
  },
  "ts-node": {
    "files": true,
    "esm": true
  }
}